# --- Python ---
__pycache__/
*.pyc

# --- Build output (PyInstaller) ---
/build/
/dist/

# --- Node ---
node_modules/

# --- Secrets / credentials ---
token.txt
Expo/school-scenario/mapbox.txt

# --- Local-only notes (not published) ---
/Guide.txt

# --- Launcher-created environment & logs ---
/.venv/
launcher.log

# Local renderer preference (maplibre/mapbox)
/data/renderer_config.json

# Facilitator-uploaded data layers & their catalog (per-deployment, not source)
/data/custom_layers/
/data/data_layer_catalog.json
# Large per-deployment source assets for the data layers (uMap backup + export)
/data/*.umap
/data/institut_polytechnique_de_paris.geojson

# Runtime-generated marker settings
/data/marker_settings.json

# Recorded media & audio
/audio_chunks/
/backend_recordings/

# Workshop session data (per-deployment, not source)
/sessions/
/cache/

# Uploaded floorplans (per-deployment, DXF uploads land here)
/floorplan/*
!/floorplan/.gitkeep

# Runtime-generated marker images
/web/apriltags/

# Site/deployment-specific data & calibration
ip_paris_amenities.geojson
calibration_offsets.json

# Large regenerable datasets (rebuild with Expo/school-scenario/tools/download_paris_arrondissement_roads.py)
/Expo
Expo/school-scenario/data/*
!Expo/school-scenario/data/.gitkeep
