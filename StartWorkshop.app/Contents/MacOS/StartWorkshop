#!/bin/bash
# Double-click launcher for the participatory mapping workshop (macOS).
# Finds a Python 3 with the dependencies, or bootstraps a .venv from
# requirements.txt, then runs app.py from the repo root. Output goes to
# launcher.log next to app.py.
set -u

ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
cd "$ROOT"
exec >>"$ROOT/launcher.log" 2>&1
echo "=== $(date) StartWorkshop ==="

PY="$(command -v python3 || true)"
if [ -z "$PY" ]; then
  osascript -e 'display alert "Python 3 is required" message "Install it from python.org/downloads and open Start Workshop again."' >/dev/null 2>&1
  exit 1
fi

DEPS="import flask, cv2, numpy, pupil_apriltags"

# A system Python that already has the dependencies wins — no venv needed.
if "$PY" -c "$DEPS" 2>/dev/null; then
  exec "$PY" app.py
fi

VENV="$ROOT/.venv"
if [ ! -x "$VENV/bin/python" ]; then
  echo "[Launcher] First run: creating .venv ..."
  "$PY" -m venv "$VENV" || exit 1
fi
if ! "$VENV/bin/python" -c "$DEPS" 2>/dev/null; then
  echo "[Launcher] First run: installing requirements (this takes a few minutes) ..."
  "$VENV/bin/python" -m pip install --upgrade pip
  "$VENV/bin/python" -m pip install -r requirements.txt || {
    osascript -e 'display alert "Setup failed" message "Dependency install failed — see launcher.log in the project folder."' >/dev/null 2>&1
    exit 1
  }
fi
exec "$VENV/bin/python" app.py
